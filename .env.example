COMPOSE_PROJECT_NAME=goodini-news-autoposter

# PostgreSQL
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=n8n

# n8n
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_PORT=5678
N8N_EDITOR_BASE_URL=http://localhost:5678
WEBHOOK_URL=http://localhost:5678/
N8N_ENCRYPTION_KEY=change-me-to-a-long-random-string
GENERIC_TIMEZONE=Asia/Tashkent

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_TRANSCRIPTION_MODEL=whisper-1

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_or_channel_id_here

# Bonus RSS input
RSS_FEED_URL=https://www.youtube.com/feeds/videos.xml?channel_id=YOUR_CHANNEL_ID
